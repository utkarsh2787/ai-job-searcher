# ─── Kafka ───────────────────────────────────
KAFKA_BROKERS=localhost:9094
KAFKA_TOPIC_RAW=job.raw.feed
KAFKA_TOPIC_PROCESSED=job.processed
KAFKA_TOPIC_DEAD_LETTER=job.dead-letter

# ─── Elasticsearch ───────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_JOBS=jobs

# ─── PostgreSQL ──────────────────────────────
POSTGRES_URL=postgresql://jip_user:jip_password@localhost:5432/job_intelligence

# ─── Redis ───────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── External APIs ───────────────────────────
ADZUNA_APP_ID=your_app_id_here
ADZUNA_APP_KEY=your_app_key_here
THEMUSE_API_KEY=your_themuse_key_here

# ─── Search API ──────────────────────────────
SEARCH_API_PORT=3001
SEARCH_API_URL=http://localhost:3001

# ─── Frontend ────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
